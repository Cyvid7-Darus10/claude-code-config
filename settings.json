{
  "permissions": {
    "deny": [
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.env)",
      "Read(**/credentials*)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/secrets*)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/*)",
      "Write(~/.env)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(curl * -d *)",
      "Bash(curl * --data *)",
      "Bash(curl * -F *)",
      "Bash(wget --post-data *)",
      "Bash(git remote add *)",
      "Bash(npm publish*)",
      "Bash(nc *)",
      "Bash(netcat *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "\"$HOME/.claude/monitoring/hooks/session-restore.sh\""
          }
        ],
        "description": "Restore previous session context for continuity"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "\"$HOME/.claude/monitoring/hooks/task-router.sh\""
          }
        ],
        "description": "Suggest the right agent/workflow based on prompt"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "timeout": 10,
            "command": "\"$HOME/.claude/monitoring/hooks/pre-compact-checkpoint.sh\""
          }
        ],
        "description": "Save working state checkpoint before context compaction"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "timeout": 5,
            "command": "\"$HOME/.claude/monitoring/hooks/session-persist.sh\""
          }
        ],
        "description": "Auto-save session state for cross-session continuity"
      }
    ]
  },
  "effortLevel": "high"
}
