{
  "permissions": {
    "deny": [
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.env)",
      "Read(**/credentials*)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/secrets*)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/*)",
      "Write(~/.env)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(curl * -d *)",
      "Bash(curl * --data *)",
      "Bash(curl * -F *)",
      "Bash(wget --post-data *)",
      "Bash(git remote add *)",
      "Bash(npm publish*)",
      "Bash(nc *)",
      "Bash(netcat *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/pre-read.mjs\""
          }
        ],
        "description": "Block duplicate file reads to save context tokens"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/compress.mjs\""
          }
        ],
        "description": "Compress noisy tool output before it bloats context"
      }
    ]
  },
  "effortLevel": "high"
}
